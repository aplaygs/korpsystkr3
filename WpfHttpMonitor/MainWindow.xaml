<Window x:Class="WpfHttpMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Система Мониторинга HTTP" Height="650" Width="1000" Background="#F0F2F5"
        WindowStartupLocation="CenterScreen">
    
    <Grid>
        <TabControl Margin="10,10,10,10" Background="White" BorderBrush="#D1D5DB" BorderThickness="1">
            
            <!-- Вкладка: HTTP Сервер -->
            <TabItem Header="HTTP-Сервер" Padding="15,5">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Настройки запуска -->
                    <Border Grid.Row="0" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15" Background="#F9FAFB">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Порт:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14" FontWeight="SemiBold"/>
                            <TextBox x:Name="PortTextBox" Width="100" Text="8080" VerticalContentAlignment="Center" Margin="0,0,15,0" Padding="5,0"/>
                            <Button x:Name="StartServerBtn" Content="Запустить сервер" Width="160" Click="StartServerBtn_Click" Padding="10,5" Background="#3B82F6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            
                            <Border Margin="20,0,0,0" Padding="10,5" CornerRadius="5" Background="#F3F4F6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Статус:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock x:Name="ServerStatusTextBlock" FontWeight="Bold" Foreground="#EF4444" Text="Остановлен" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                    <!-- Логи сервера (Текстовое поле) -->
                    <GroupBox Header="Логи работы сервера (входящие запросы)" Grid.Row="1" FontSize="14" BorderBrush="#E5E7EB">
                        <TextBox x:Name="ServerLogsTextBox" IsReadOnly="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" FontFamily="Consolas" Background="#1E1E1E" Foreground="#D4D4D4" Margin="5"/>
                    </GroupBox>
                </Grid>
            </TabItem>
            
            <!-- Вкладка: HTTP Клиент -->
            <TabItem Header="HTTP-Клиент" Padding="15,5">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Настройки запроса -->
                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="Метод:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14" FontWeight="SemiBold"/>
                        <ComboBox x:Name="MethodComboBox" Width="100" Margin="0,0,20,0" SelectedIndex="0" Padding="5">
                            <ComboBoxItem Content="GET"/>
                            <ComboBoxItem Content="POST"/>
                        </ComboBox>
                        <TextBlock Text="URL:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14" FontWeight="SemiBold"/>
                        <TextBox x:Name="UrlTextBox" Width="500" Text="https://jsonplaceholder.typicode.com/posts/1" VerticalContentAlignment="Center" Margin="0,0,15,0" Padding="5,2"/>
                    </StackPanel>
                    
                    <GroupBox Header="Тело запроса (JSON - используется только для POST)" Grid.Row="1" Height="120" Margin="0,0,0,15" BorderBrush="#E5E7EB">
                        <TextBox x:Name="RequestBodyTextBox" Text="{}{&quot;title&quot;: &quot;foo&quot;, &quot;body&quot;: &quot;bar&quot;, &quot;userId&quot;: 1}" TextWrapping="Wrap" AcceptsReturn="True" FontFamily="Consolas" Margin="5" Padding="5"/>
                    </GroupBox>
                    
                    <GroupBox Header="Тело ответа" Grid.Row="2" Margin="0,0,0,15" BorderBrush="#E5E7EB">
                        <TextBox x:Name="ClientResponseTextBox" IsReadOnly="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" FontFamily="Consolas" Background="#F8FAFC" Margin="5" Padding="5"/>
                    </GroupBox>
                    
                    <Button x:Name="SendRequestBtn" Content="Отправить запрос" Grid.Row="3" Width="220" HorizontalAlignment="Right" Click="SendRequestBtn_Click" Padding="10,8" Background="#10B981" Foreground="White" BorderThickness="0" Cursor="Hand" FontSize="14" FontWeight="SemiBold"/>
                </Grid>
            </TabItem>
            
            <!-- Вкладка: Мониторинг и Аналитика -->
            <TabItem Header="Мониторинг и Аналитика" Padding="15,5">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <GroupBox Header="Статистика сервера" Grid.Row="0" Margin="0,0,0,15" BorderBrush="#E5E7EB">
                        <WrapPanel x:Name="StatsPanel" Margin="10">
                            <TextBlock x:Name="StatsTextBlock" Text="Ожидание запуска сервера..." FontSize="14" FontWeight="Medium"/>
                        </WrapPanel>
                    </GroupBox>
                    
                    <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,15">
                        <TextBlock Text="Фильтр по методу:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="FilterMethodComboBox" Width="100" Margin="0,0,20,0" SelectionChanged="FilterComboBox_SelectionChanged" SelectedIndex="0">
                            <ComboBoxItem Content="Все"/>
                            <ComboBoxItem Content="GET"/>
                            <ComboBoxItem Content="POST"/>
                        </ComboBox>
                        
                        <TextBlock Text="Фильтр по статусу:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="FilterStatusTextBox" Width="100" TextChanged="FilterKeywordTextBox_TextChanged" Margin="0,0,20,0" Padding="5,2" ToolTip="Например: 200 или 201"/>

                        <TextBlock Text="Поиск в URL:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="FilterKeywordTextBox" Width="200" TextChanged="FilterKeywordTextBox_TextChanged" Margin="0,0,10,0" Padding="5,2"/>
                    </StackPanel>
                    
                    <DataGrid x:Name="LogsDataGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" AlternatingRowBackground="#F9FAFB" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E5E7EB" BorderBrush="#E5E7EB">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Время" Binding="{Binding Timestamp, StringFormat={}{0:HH:mm:ss.fff}}" Width="120"/>
                            <DataGridTextColumn Header="Тип" Binding="{Binding Direction}" Width="100"/>
                            <DataGridTextColumn Header="Метод" Binding="{Binding Method}" Width="70"/>
                            <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="*"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding ResponseStatus}" Width="80"/>
                            <DataGridTextColumn Header="Длительность (мс)" Binding="{Binding DurationMs}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
